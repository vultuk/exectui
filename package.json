{
  "name": "exectui",
  "version": "0.1.0",
  "module": "src/index.tsx",
  "type": "module",
  "private": false,
  "description": "Terminal workflow cockpit for GitHub issues and pull requests",
  "bin": {
    "exectui": "./bin/exectui.mjs"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "react": "^19.2.4"
  }
}
